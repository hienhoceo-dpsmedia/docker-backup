# Docker Backup Manager - Environment Configuration
# Copy this file to .env and update with your values

# ============================================
# TIMEZONE
# ============================================
TZ=Asia/Ho_Chi_Minh

# ============================================
# TELEGRAM INTEGRATION (Optional)
# ============================================
# Leave empty to disable Telegram notifications
# Get your bot token from @BotFather on Telegram
TELEGRAM_TOKEN=

# Telegram API root (leave as default unless using custom API)
TELEGRAM_API_ROOT=https://api.telegram.org

# Your Telegram Chat ID (get it from @userinfobot)
CHAT_ID=

# ============================================
# BACKUP SETTINGS
# ============================================
# ZIP compression level (1-9). Lower = less CPU, larger file.
BACKUP_ZIP_LEVEL=4

# Set to true only if you intentionally want to archive raw DB data volumes.
# Default false to avoid heavy I/O on production DB containers.
INCLUDE_DB_VOLUME_BACKUP=false

# Capacity gate: defer backup when system is under pressure
BACKUP_MAX_LOADAVG=1.8
BACKUP_MAX_DISK_UTIL=85
BACKUP_CHECK_INTERVAL_MS=30000
BACKUP_MAX_DEFERRALS=20
BACKUP_DISK_SAMPLE_MS=1000
BACKUP_RESOURCE_SAMPLE_MS=1000

# These are configured in the web UI, but can be set here for initial setup
# RETENTION_COUNT=10
# BACKUP_FREQUENCY=daily
# BACKUP_TIME=02:00
